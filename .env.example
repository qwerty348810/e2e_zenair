# Скопируй этот файл в .env и заполни. .env в .gitignore — в репозиторий не попадёт.

# Доступ к сайту под паролем (форма auth.php)
ZEN_BASE_URL=https://zenair.by
ZEN_LOGIN=admin
ZEN_PASSWORD=

# Имя товара для пути «каталог → товар → в корзину».
# По умолчанию Gree-Airy-black (подтверждён). Поменяй, если тестируешь другой.
ZEN_PRODUCT_NAME=Gree-Airy-black
