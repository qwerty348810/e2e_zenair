{
  "name": "zenair-e2e",
  "version": "1.0.0",
  "description": "End-to-end tests for the ZenAir WooCommerce store (password-protected dev site), built with Playwright + TypeScript.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "codegen": "playwright codegen --load-storage=.auth/state.json https://zenair.by"
  },
  "keywords": ["qa", "e2e", "playwright", "typescript", "woocommerce"],
  "author": "Dmitry Yakovlev",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "typescript": "^5.7.0"
  }
}
